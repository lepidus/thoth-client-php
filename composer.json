{
    "name": "thoth-pub/thoth-client-php",
    "description": "PHP client for Thoth's GraphQL and REST APIs.",
    "type": "library",
    "require": {
        "php": ">=7.4",
        "guzzlehttp/guzzle": "^6.5 | ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.2"
    },
    "config": {
        "platform": {
            "php": "7.4.33"
        }
    },
    "license": "Apache-2.0",
    "autoload": {
        "psr-4": {
            "ThothApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThothApi\\Tests\\": "tests/"
        }
    },
    "scripts" : {
        "test": "vendor/bin/phpunit --colors --testdox tests/",
        "analyse": "vendor/bin/phpstan analyse --debug --memory-limit=1G",
        "lint": "vendor/bin/php-cs-fixer fix -v --diff --allow-risky=yes --config=.php-cs-fixer.php",
        "generate-graphql-client": "php tools/generate-graphql-client.php"
    }
}
